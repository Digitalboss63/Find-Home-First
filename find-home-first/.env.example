# PostgreSQL connection string — required for live database reads.
DATABASE_URL=

# Clerk authentication — required in production.
# Obtain from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk fallback redirect URLs (current convention — replaces AFTER_SIGN_IN/AFTER_SIGN_UP)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Demo mode — set to "true" in development only. Never in production.
DEMO_MODE=
